# Secrets
.env

# Virtual environment & caches
.venv/
.cache/
*.log

# Raw data (large; downloaded by src.ml.get_data)
data/raw/
data/processed/

# CFPB PDFs (downloaded/regenerated by src.rag.corpus); keep the .txt sources out too
docs/cfpb/*.pdf

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
.DS_Store
.ipynb_checkpoints/

# NOTE: models/ and vectorstore/ are intentionally COMMITTED so the
# Streamlit Cloud demo can load them without retraining/re-ingesting.
