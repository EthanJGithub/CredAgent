# ── LLM backend (optional) ───────────────────────────────────────────────────
# The pipeline runs WITHOUT any key (deterministic offline reasoning). Set one
# of these to enable LLM-authored compliance analysis, decision reasoning and
# adverse-action letters.
#
# Groq is free with no credit card: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant

# Alternatively use Anthropic Claude:
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Paths ─────────────────────────────────────────────────────────────────────
MODEL_PATH=models/
VECTORSTORE_PATH=vectorstore/
DATA_PATH=data/
LOG_LEVEL=INFO

# ── Keep caches off the C: drive (optional, Windows) ─────────────────────────
# Point HuggingFace / ChromaDB model caches at a roomier drive if needed.
# HF_HOME=D:/credagent_cache/hf
